{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI (Backend)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "env": {
        "envPath": "${workspaceFolder}"
      },
      "cwd": "${workspaceFolder}/server",
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "React (Frontend)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src"
    }
  ],
  "compounds": [
    {
      "name": "Fullstack Debug (React + FastAPI)",
      "configurations": ["FastAPI (Backend)", "React (Frontend)"]
    }
  ]
}